  "keyFeatures": [
    "Role-based access control with four user roles: Customer, Seller, Cashier, Administrator",
    "Full product catalog with categories, discounts, and inventory management",
    "Shopping cart and multi-step checkout flow with card payment support",
    "Point-of-sale cashier panel for in-store transactions",
    "Admin dashboard for managing products, categories, and users",
    "Real-time chat between users",
    "Sales reports with PDF export (jsPDF + autotable)",
    "Order tracking and shipment status",
    "Supabase-powered authentication with password reset",
    "Cloudinary integration for product image storage"
  ],
  "publicApiSurface": [
    "useAuthStore — inicializarSesion, cerrarSesion, cargarPerfil, crearPerfil",
    "useProductStore — fetchProducts, fetchCategorias, decreaseStock, increaseStock, updateStockInDB",
    "useCartStore — cart state and checkout helpers",
    "useNotificationStore — notification management",
    "useVentasStore — sales tracking",
    "usePaymentCheckout — checkout flow composable",
    "useCreditCardFormatters — card number/expiry formatting",
    "useTicketGenerator — PDF receipt generation",
    "useChat — real-time chat composable",
    "useRole — role-based UI helpers"
  ]
}
